/* Reset & basics */
* {
  box-sizing: border-box;
}
body, html {
  margin: 0;
  padding: 0;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background: #f3f6f9;
  color: #1a1a1a;
  scroll-behavior: smooth;
}

.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 1rem;
}



/* HEADER STYLING */
.site-header {
  position: fixed;
  top: 0;
  width: 100%;
  background: linear-gradient(90deg, #1a1a1aee, #111111ee);
  color: #f3c623; /* gold */
  box-shadow: 0 4px 15px rgba(0,0,0,0.7);
  z-index: 9999;
  backdrop-filter: saturate(180%) blur(12px);
  -webkit-backdrop-filter: saturate(180%) blur(12px);
}

.header-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0.8rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.brand {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-weight: 900;
  font-size: 1.5rem;
  font-family: 'Segoe UI Black', 'Arial Black', Arial, sans-serif;
  user-select: none;
  cursor: pointer;
  text-decoration: none;
  color: #f3c623; /* gold */
  transition: color 0.3s ease;
}

.brand:hover {
  color: #fff4b8;
}

.brand .logo {
  height: 44px;
  width: 44px;
  object-fit: contain;
  filter: drop-shadow(0 0 4px #f3c623cc);
  transition: transform 0.3s ease;
}

.brand:hover .logo {
  transform: scale(1.1);
}

.main-nav {
  display: flex;
  gap: 1.6rem;
  font-weight: 700;
  font-size: 1rem;
  align-items: center;
}

.main-nav .nav-link {
  text-decoration: none;
  color: #f3c623;
  padding: 0.5rem 0.8rem;
  border-radius: 8px;
  position: relative;
  transition: color 0.3s ease;
  user-select: none;
}

.main-nav .nav-link::after {
  content: '';
  position: absolute;
  width: 0%;
  height: 3px;
  bottom: 0;
  left: 0;
  background: #f3c623;
  transition: width 0.3s ease;
  border-radius: 4px;
}

.main-nav .nav-link:hover,
.main-nav .nav-link.active {
  color: #fff;
}

.main-nav .nav-link:hover::after,
.main-nav .nav-link.active::after {
  width: 100%;
}

/* Hamburger button */
.nav-toggle {
  display: none;
  background: transparent;
  border: none;
  font-size: 2.2rem;
  color: #f3c623;
  cursor: pointer;
  user-select: none;
  transition: color 0.3s ease;
}

.nav-toggle:hover {
  color: #fff4b8;
}

/* Responsive for smaller screens */
@media (max-width: 700px) {
  .nav-toggle {
    display: block;
  }
  .main-nav {
    position: fixed;
    top: 60px;
    right: 1rem;
    background: #1a1a1aee;
    border-radius: 12px;
    padding: 1.2rem 1.6rem;
    flex-direction: column;
    gap: 1.4rem;
    box-shadow: 0 0 20px #f3c623cc;
    display: none;
    width: 220px;
  }
  .main-nav.open {
    display: flex;
  }
  .main-nav .nav-link {
    font-size: 1.1rem;
  }
}










